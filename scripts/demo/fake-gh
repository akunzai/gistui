#!/usr/bin/env python3
"""Minimal stateful fake `gh` for the gistui demo recording.

Implements only the command surface gistui actually uses, backed by a JSON gist
store at $GISTUI_DEMO_HOME/state/gists.json. Mutating commands (edit/create/
delete/description PATCH) update the store so the TUI reflects changes across
its many subprocess calls. Put this directory first on PATH and gistui talks to
fake data instead of a real GitHub account.
"""
import datetime
import json
import os
import pathlib
import sys

STATE = pathlib.Path(os.environ["GISTUI_DEMO_HOME"]) / "state" / "gists.json"


def load():
    return json.loads(STATE.read_text())


def save(d):
    STATE.write_text(json.dumps(d, indent=2))


def now():
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def main():
    a = sys.argv[1:]

    # readiness checks: gh --version / gh auth status
    if a == ["--version"]:
        print("gh version 2.62.0 (2026-01-01)")
        return 0
    if a[:2] == ["auth", "status"]:
        sys.stderr.write(
            "github.com\n  ✓ Logged in to github.com account demo (keyring)\n"
        )
        return 0

    # list: gh api --paginate /gists?per_page=100
    if a[:2] == ["api", "--paginate"] and a[2].startswith("/gists"):
        d = load()
        out = [
            {
                "id": gid,
                "description": g.get("description"),
                "public": g.get("public", False),
                "updated_at": g.get("updated_at", ""),
                "created_at": g.get("created_at", ""),
                "comments": g.get("comments", 0),
                "files": {fn: {"filename": fn} for fn in g["files"]},
            }
            for gid, g in d["gists"].items()
        ]
        print(json.dumps(out))
        return 0

    # description edit: gh api --method PATCH /gists/<id> -f description=...
    if a[:1] == ["api"] and "--method" in a and "PATCH" in a:
        gid = a[a.index("PATCH") + 1].split("/gists/")[-1]
        desc = a[a.index("-f") + 1].split("description=", 1)[-1] if "-f" in a else ""
        d = load()
        if gid in d["gists"]:
            d["gists"][gid]["description"] = desc
            d["gists"][gid]["updated_at"] = now()
            save(d)
        print(json.dumps({"id": gid, "description": desc}))
        return 0

    if a[:2] == ["gist", "view"]:
        gid = a[2]
        if "--web" in a:
            return 0  # would open a browser; no-op for the recording
        if "--filename" in a and "--raw" in a:
            fn = a[a.index("--filename") + 1]
            d = load()
            sys.stdout.write(d["gists"].get(gid, {}).get("files", {}).get(fn, ""))
            return 0
        return 0

    if a[:2] == ["gist", "edit"]:
        gid = a[2]
        d = load()
        g = d["gists"].setdefault(
            gid, {"description": "", "public": False, "created_at": now(), "files": {}}
        )
        if "--remove" in a:
            g["files"].pop(a[a.index("--remove") + 1], None)
        elif "--add" in a:
            path = a[a.index("--add") + 1]
            g["files"][os.path.basename(path)] = pathlib.Path(path).read_text()
        elif "--filename" in a:
            fn = a[a.index("--filename") + 1]
            g["files"][fn] = pathlib.Path(a[-1]).read_text()
        g["updated_at"] = now()
        save(d)
        return 0

    if a[:2] == ["gist", "create"]:
        path = a[2]
        d = load()
        gid = "g_new" + os.urandom(3).hex()
        d["gists"][gid] = {
            "description": a[a.index("--desc") + 1] if "--desc" in a else "",
            "public": "--public" in a,
            "updated_at": now(),
            "created_at": now(),
            "files": {os.path.basename(path): pathlib.Path(path).read_text()},
        }
        save(d)
        print(f"https://gist.github.com/{gid}")
        return 0

    if a[:2] == ["gist", "delete"]:
        d = load()
        d["gists"].pop(a[-1], None)
        save(d)
        return 0

    sys.stderr.write(f"fake gh: unhandled args: {a}\n")
    return 1


if __name__ == "__main__":
    sys.exit(main())
