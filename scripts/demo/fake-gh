#!/usr/bin/env python3
"""Minimal stateful fake `gh` for the gistui demo recording.

Implements only the command surface gistui actually uses, backed by a JSON gist
store at $GISTUI_DEMO_HOME/state/gists.json. Mutating commands (edit/create/
delete/description PATCH) update the store so the TUI reflects changes across
its many subprocess calls. Put this directory first on PATH and gistui talks to
fake data instead of a real GitHub account.
"""
import datetime
import json
import os
import pathlib
import re
import sys

STATE = pathlib.Path(os.environ["GISTUI_DEMO_HOME"]) / "state" / "gists.json"
DEMO_USER = "demo"

# MIME hints so preview/diff syntax highlighting picks the right highlighter.
FILE_TYPES = {
    "starship.toml": "text/plain",
    "aliases.sh": "application/x-shellscript",
    "hello.py": "text/x-python",
    "tmux.conf": "text/plain",
    "notes.md": "text/markdown",
}


def load():
    return json.loads(STATE.read_text())


def save(d):
    STATE.write_text(json.dumps(d, indent=2))


def now():
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def gist_api_row(gid, g):
    fork_n = int(g.get("forks", 0))
    return {
        "id": gid,
        "node_id": g.get("node_id", f"GIST_{gid}"),
        "description": g.get("description"),
        "public": g.get("public", False),
        "updated_at": g.get("updated_at", ""),
        "created_at": g.get("created_at", ""),
        "comments": g.get("comments", 0),
        "owner": {"login": DEMO_USER},
        "forks": [{"id": f"{gid}_fork{i}"} for i in range(fork_n)],
        "files": {
            fn: {
                "filename": fn,
                "type": FILE_TYPES.get(fn, "text/plain"),
            }
            for fn in g["files"]
        },
    }


def gist_list(starred_only=False):
    d = load()
    rows = [gist_api_row(gid, g) for gid, g in d["gists"].items()]
    if starred_only:
        # Keep the main list free of ★ badges; starred gists are a separate concern.
        return []
    return rows


def node_stargazer_count(node_id):
    d = load()
    for g in d["gists"].values():
        if g.get("node_id") == node_id:
            return int(g.get("stargazers", 0))
    return 0


def graphql_response(query):
    if "viewer" in query and "isFork" in query:
        d = load()
        nodes = [
            {"name": gid, "isFork": bool(g.get("is_fork", False))}
            for gid, g in d["gists"].items()
        ]
        return {"data": {"viewer": {"gists": {"nodes": nodes}}}}

    if "stargazerCount" in query:
        d = load()
        by_node = {g.get("node_id"): gid for gid, g in d["gists"].items()}
        node_ids = re.findall(r'node\(id: "([^"]+)"\)', query)
        data = {}
        for i, node_id in enumerate(node_ids):
            gid = by_node.get(node_id, node_id)
            data[f"n{i}"] = {
                "name": gid,
                "stargazerCount": node_stargazer_count(node_id),
            }
        return {"data": data}

    return {"data": {}}


def main():
    a = sys.argv[1:]

    if a == ["--version"]:
        print("gh version 2.62.0 (2026-01-01)")
        return 0
    if a[:2] == ["auth", "status"]:
        sys.stderr.write(
            f"github.com\n  ✓ Logged in to github.com account {DEMO_USER} (keyring)\n"
        )
        return 0

    if a[:3] == ["api", "user", "--jq"] and a[3] == ".login":
        print(DEMO_USER)
        return 0

    if a[:2] == ["api", "graphql"]:
        query = ""
        for i, arg in enumerate(a):
            if arg == "-f" and i + 1 < len(a) and a[i + 1].startswith("query="):
                query = a[i + 1].split("query=", 1)[1]
                break
        print(json.dumps(graphql_response(query)))
        return 0

    if a[:2] == ["api", "--paginate"] and len(a) > 2:
        path = a[2]
        if path.startswith("/gists/starred"):
            print(json.dumps(gist_list(starred_only=True)))
            return 0
        if path.startswith("/gists"):
            print(json.dumps(gist_list(starred_only=False)))
            return 0

    if len(a) >= 3 and a[:2] == ["api"] and a[2].startswith("/gists/"):
        tail = a[2].split("/gists/", 1)[1]
        if "/" in tail:
            gid, rest = tail.split("/", 1)
            if rest == "comments":
                print("[]")
                return 0
            if rest.startswith("forks"):
                d = load()
                g = d["gists"].get(gid, {})
                n = int(g.get("forks", 0))
                print(json.dumps([{"id": f"{gid}_fork{i}"} for i in range(n)]))
                return 0
        else:
            gid = tail
            d = load()
            g = d["gists"].get(gid)
            if g:
                print(json.dumps(gist_api_row(gid, g)))
                return 0
        return 0

    if a[:1] == ["api"] and "--method" in a and "PATCH" in a:
        gid = a[a.index("PATCH") + 1].split("/gists/")[-1]
        desc = a[a.index("-f") + 1].split("description=", 1)[-1] if "-f" in a else ""
        d = load()
        if gid in d["gists"]:
            d["gists"][gid]["description"] = desc
            d["gists"][gid]["updated_at"] = now()
            save(d)
        print(json.dumps({"id": gid, "description": desc}))
        return 0

    if a[:2] == ["gist", "view"]:
        gid = a[2]
        if "--web" in a:
            return 0
        if "--filename" in a and "--raw" in a:
            fn = a[a.index("--filename") + 1]
            d = load()
            sys.stdout.write(d["gists"].get(gid, {}).get("files", {}).get(fn, ""))
            return 0
        return 0

    if a[:2] == ["gist", "edit"]:
        gid = a[2]
        d = load()
        g = d["gists"].setdefault(
            gid, {"description": "", "public": False, "created_at": now(), "files": {}}
        )
        if "--remove" in a:
            g["files"].pop(a[a.index("--remove") + 1], None)
        elif "--add" in a:
            path = a[a.index("--add") + 1]
            g["files"][os.path.basename(path)] = pathlib.Path(path).read_text()
        elif "--filename" in a:
            fn = a[a.index("--filename") + 1]
            g["files"][fn] = pathlib.Path(a[-1]).read_text()
        g["updated_at"] = now()
        save(d)
        return 0

    if a[:2] == ["gist", "create"]:
        path = a[2]
        d = load()
        gid = "g_new" + os.urandom(3).hex()
        d["gists"][gid] = {
            "description": a[a.index("--desc") + 1] if "--desc" in a else "",
            "public": "--public" in a,
            "updated_at": now(),
            "created_at": now(),
            "files": {os.path.basename(path): pathlib.Path(path).read_text()},
        }
        save(d)
        print(f"https://gist.github.com/{gid}")
        return 0

    if a[:2] == ["gist", "delete"]:
        d = load()
        d["gists"].pop(a[-1], None)
        save(d)
        return 0

    sys.stderr.write(f"fake gh: unhandled args: {a}\n")
    return 1


if __name__ == "__main__":
    sys.exit(main())